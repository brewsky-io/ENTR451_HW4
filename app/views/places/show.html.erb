<h1><%= @place["name"] %></h1>

<% if @current_user != nil %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-outline-dark">New Entry</a>
  </p>
<% end %>

<div class="row mt-3">
  <% for entry in @entries %>
    <div class="col-lg-4 col-md-6 mb-3">
      <h3><%= entry["title"] %></h3>
      <h4><%= entry["occurred_on"] %></h4>
      <% if entry.uploaded_image.attached? %>
        <img src="<%= url_for(entry.uploaded_image) %>" class="img-fluid w-100">
      <% end %>
      <p><%= entry["description"] %></p>
    </div>
  <% end %>
</div>

<p>
  <a href="/places">Back to All Places</a>
</p>